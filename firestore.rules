rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return signedIn() &&
        request.auth.token.email == 'm.osmandonmezyurek@gmail.com';
    }

    function membershipPath(companyId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId);
    }

    function isMember(companyId) {
      return signedIn() && exists(membershipPath(companyId)) &&
        (
          !get(membershipPath(companyId)).data.keys().hasAny(['supportExpiresAt']) ||
          request.time < get(membershipPath(companyId)).data.supportExpiresAt
        );
    }

    function isOwner(companyId) {
      return isMember(companyId) && get(membershipPath(companyId)).data.role == 'OWNER';
    }

    function hasPermission(companyId, permission) {
      return isOwner(companyId) ||
        (isMember(companyId) &&
          get(membershipPath(companyId)).data.permissions.hasAny([permission]));
    }

    function hasCompanyOnCreate(companyId) {
      return request.resource.data.companyId == companyId;
    }

    function keepsCompany(companyId) {
      return resource.data.companyId == companyId &&
        request.resource.data.companyId == companyId;
    }

    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function isLegacyUserData() {
      return signedIn() && !resource.data.keys().hasAny(['companyId']) &&
        resource.data.userId == request.auth.uid;
    }

    function migratesLegacyData() {
      return isLegacyUserData() &&
        request.resource.data.userId == request.auth.uid &&
        isOwner(request.resource.data.companyId);
    }

    function isValidSupportScreenshot() {
      return request.resource.data.screenshot == null ||
        (
          request.resource.data.screenshot is map &&
          request.resource.data.screenshot.keys().hasOnly(['dataUrl', 'name', 'sizeBytes']) &&
          request.resource.data.screenshot.dataUrl is string &&
          request.resource.data.screenshot.dataUrl.matches('^data:image/webp;base64,.*') &&
          request.resource.data.screenshot.dataUrl.size() <= 500000 &&
          request.resource.data.screenshot.name is string &&
          request.resource.data.screenshot.name.size() <= 160 &&
          request.resource.data.screenshot.sizeBytes is number &&
          request.resource.data.screenshot.sizeBytes <= 358400
        );
    }

    function isValidSupportReport(reportId) {
      return request.resource.data.keys().hasOnly([
          'id', 'type', 'title', 'description', 'status', 'createdBy',
          'createdByEmail', 'recipientEmail', 'companyId', 'companyName',
          'route', 'appVersion', 'client', 'technicalErrors', 'screenshot',
          'createdAt'
        ]) &&
        request.resource.data.id == reportId &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.recipientEmail == 'm.osmandonmezyurek@gmail.com' &&
        request.resource.data.type in ['BUG', 'SUPPORT', 'SUGGESTION'] &&
        request.resource.data.status == 'OPEN' &&
        request.resource.data.companyId is string &&
        isMember(request.resource.data.companyId) &&
        request.resource.data.companyName is string &&
        request.resource.data.companyName.size() <= 120 &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 3 &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() >= 5 &&
        request.resource.data.description.size() <= 1500 &&
        request.resource.data.route is string &&
        request.resource.data.route.size() <= 500 &&
        request.resource.data.appVersion is string &&
        request.resource.data.appVersion.size() <= 100 &&
        request.resource.data.client is map &&
        request.resource.data.technicalErrors is list &&
        request.resource.data.technicalErrors.size() <= 10 &&
        request.resource.data.createdAt is string &&
        isValidSupportScreenshot();
    }

    function isValidSupportNotification(notificationId) {
      return request.resource.data.keys().hasOnly([
          'id', 'kind', 'recipientEmail', 'title', 'body', 'resourceType',
          'resourceId', 'createdBy', 'companyId', 'isRead', 'createdAt', 'delivery'
        ]) &&
        request.resource.data.id == notificationId &&
        request.resource.data.kind == 'SUPPORT_REPORT' &&
        request.resource.data.recipientEmail == 'm.osmandonmezyurek@gmail.com' &&
        request.resource.data.title == 'Yeni destek kaydı' &&
        request.resource.data.body is string &&
        request.resource.data.body.size() <= 350 &&
        request.resource.data.resourceType == 'supportReport' &&
        request.resource.data.resourceId is string &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.companyId is string &&
        isMember(request.resource.data.companyId) &&
        request.resource.data.isRead == false &&
        request.resource.data.createdAt is string &&
        request.resource.data.delivery is map;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId &&
        request.resource.data.id == userId;
    }

    match /userPreferences/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /companies/{companyId} {
      allow create: if signedIn() && request.resource.data.id == companyId &&
        request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(companyId) || isPlatformAdmin();
      allow update: if isOwner(companyId) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.ownerId == resource.data.ownerId;
    }

    match /memberships/{membershipId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          hasPermission(resource.data.companyId, 'VIEW_SALES_HISTORY') ||
          isPlatformAdmin()
        );

      allow create: if signedIn() && request.resource.data.id == membershipId &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.companyId != null &&
          (
            (
              isPlatformAdmin() &&
            request.resource.data.keys().hasOnly([
              'id', 'userId', 'email', 'companyId', 'companyName', 'role',
              'permissions', 'createdAt', 'supportSessionId',
              'supportTargetUserId', 'supportExpiresAt'
            ]) &&
            request.resource.data.userId == request.auth.uid &&
            membershipId == request.auth.uid + '_' + request.resource.data.companyId &&
            request.resource.data.role == 'EMPLOYEE' &&
            request.resource.data.email == request.auth.token.email &&
            request.resource.data.supportSessionId is string &&
            request.resource.data.supportTargetUserId is string &&
            request.resource.data.supportExpiresAt is timestamp &&
            request.resource.data.supportExpiresAt > request.time &&
            request.resource.data.supportExpiresAt <= request.time + duration.value(8, 'h') &&
            exists(/databases/$(database)/documents/memberships/$(request.resource.data.supportTargetUserId + '_' + request.resource.data.companyId)) &&
            existsAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)) &&
            getAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)).data.openedBy == request.auth.uid &&
            getAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)).data.status == 'ACTIVE' &&
            getAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)).data.companyId == request.resource.data.companyId &&
            getAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)).data.targetUserId == request.resource.data.supportTargetUserId &&
            getAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)).data.expiresAt == request.resource.data.supportExpiresAt &&
              getAfter(/databases/$(database)/documents/supportSessions/$(request.resource.data.supportSessionId)).data.permissionSnapshot == request.resource.data.permissions
            )
          ||
          (
            request.resource.data.role == 'OWNER' &&
            membershipId == request.auth.uid + '_' + request.resource.data.companyId &&
            get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.ownerId == request.auth.uid
          ) ||
          (
            request.resource.data.role == 'EMPLOYEE' &&
            request.resource.data.invitationId != null &&
            membershipId == request.auth.uid + '_' + request.resource.data.companyId &&
            get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.status == 'PENDING' &&
            get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.companyId == request.resource.data.companyId &&
            get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.email == request.auth.token.email &&
            request.resource.data.email == request.auth.token.email &&
            request.resource.data.permissions == get(/databases/$(database)/documents/invitations/$(request.resource.data.invitationId)).data.permissions
          )
        );

      allow update: if isOwner(resource.data.companyId) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.companyId == resource.data.companyId &&
        request.resource.data.role == resource.data.role;
      allow delete: if (
          isOwner(resource.data.companyId) &&
          resource.data.userId != request.auth.uid
        ) ||
        (
          isPlatformAdmin() && resource.data.userId == request.auth.uid &&
          resource.data.keys().hasAny(['supportSessionId'])
        );
    }

    match /supportSessions/{sessionId} {
      allow read: if isPlatformAdmin();
      allow create: if isPlatformAdmin() &&
        request.resource.data.keys().hasOnly([
          'id', 'companyId', 'companyName', 'openedBy', 'targetUserId',
          'targetMembershipId', 'permissionSnapshot', 'reason', 'status',
          'startedAt', 'expiresAt'
        ]) &&
        request.resource.data.id == sessionId &&
        request.resource.data.openedBy == request.auth.uid &&
        request.resource.data.targetMembershipId == request.resource.data.targetUserId + '_' + request.resource.data.companyId &&
        request.resource.data.status == 'ACTIVE' &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() >= 5 &&
        request.resource.data.reason.size() <= 500 &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.expiresAt > request.time &&
        request.resource.data.expiresAt <= request.time + duration.value(8, 'h') &&
        exists(/databases/$(database)/documents/memberships/$(request.resource.data.targetMembershipId)) &&
        get(/databases/$(database)/documents/memberships/$(request.resource.data.targetMembershipId)).data.companyId == request.resource.data.companyId &&
        get(/databases/$(database)/documents/memberships/$(request.resource.data.targetMembershipId)).data.userId == request.resource.data.targetUserId;
      allow update: if isPlatformAdmin() &&
        resource.data.openedBy == request.auth.uid &&
        resource.data.status == 'ACTIVE' &&
        request.resource.data.status == 'CLOSED' &&
        onlyChanges(['status', 'endedAt']) &&
        request.resource.data.endedAt is timestamp;
      allow delete: if false;
    }

    match /invitations/{invitationId} {
      allow create: if isOwner(request.resource.data.companyId) &&
        request.resource.data.id == invitationId &&
        request.resource.data.invitedBy == request.auth.uid;
      allow read: if isOwner(resource.data.companyId) ||
        (signedIn() && resource.data.email == request.auth.token.email);
      allow update: if isOwner(resource.data.companyId) ||
        (
          signedIn() && resource.data.email == request.auth.token.email &&
          resource.data.status == 'PENDING' &&
          request.resource.data.status in ['ACCEPTED', 'DECLINED'] &&
          onlyChanges(['status'])
        );
      allow delete: if isOwner(resource.data.companyId);
    }

    match /inventory/{itemId} {
      allow read: if isMember(resource.data.companyId) || isLegacyUserData();
      allow create: if hasPermission(request.resource.data.companyId, 'MANAGE_INVENTORY') &&
        hasCompanyOnCreate(request.resource.data.companyId);
      allow update: if migratesLegacyData() ||
        (
          keepsCompany(resource.data.companyId) &&
          (
            hasPermission(resource.data.companyId, 'MANAGE_INVENTORY') ||
            (isMember(resource.data.companyId) && onlyChanges(['stock', 'updatedAt']))
          )
        );
      allow delete: if hasPermission(resource.data.companyId, 'MANAGE_INVENTORY');
    }

    match /productCategories/{categoryId} {
      allow read: if isMember(resource.data.companyId);
      allow create: if hasPermission(request.resource.data.companyId, 'MANAGE_CATEGORIES') &&
        hasCompanyOnCreate(request.resource.data.companyId);
      allow update: if hasPermission(resource.data.companyId, 'MANAGE_CATEGORIES') &&
        keepsCompany(resource.data.companyId);
      allow delete: if hasPermission(resource.data.companyId, 'MANAGE_CATEGORIES');
    }

    match /customers/{customerId} {
      allow read: if isMember(resource.data.companyId) || isLegacyUserData();
      allow create: if hasPermission(request.resource.data.companyId, 'MANAGE_CUSTOMERS') &&
        hasCompanyOnCreate(request.resource.data.companyId);
      allow update: if migratesLegacyData() ||
        (
          keepsCompany(resource.data.companyId) &&
          (
            hasPermission(resource.data.companyId, 'MANAGE_CUSTOMERS') ||
            (isMember(resource.data.companyId) && onlyChanges(['totalDebt']))
          )
        );
      allow delete: if hasPermission(resource.data.companyId, 'MANAGE_CUSTOMERS');
    }

    match /sales/{saleId} {
      allow read: if isOwner(resource.data.companyId) ||
        hasPermission(resource.data.companyId, 'VIEW_SALES_HISTORY') || isLegacyUserData();
      allow create: if isMember(request.resource.data.companyId) &&
        hasCompanyOnCreate(request.resource.data.companyId) &&
        request.resource.data.userId == request.auth.uid;
      allow update: if hasPermission(resource.data.companyId, 'MANAGE_SALES_HISTORY') ||
        isOwner(resource.data.companyId) || migratesLegacyData();
      allow delete: if hasPermission(resource.data.companyId, 'MANAGE_SALES_HISTORY') ||
        isOwner(resource.data.companyId);
    }

    match /saleItems/{saleItemId} {
      allow read: if isOwner(resource.data.companyId) ||
        hasPermission(resource.data.companyId, 'VIEW_SALES_HISTORY');
      allow create: if isMember(request.resource.data.companyId) &&
        hasCompanyOnCreate(request.resource.data.companyId) &&
        request.resource.data.userId == request.auth.uid;
    }

    match /payments/{paymentId} {
      allow read: if isMember(resource.data.companyId);
      allow create: if hasPermission(request.resource.data.companyId, 'TAKE_PAYMENT') &&
        hasCompanyOnCreate(request.resource.data.companyId) &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.companyId);
    }

    match /statementShares/{shareId} {
      allow read: if hasPermission(resource.data.companyId, 'SHARE_CUSTOMER_STATEMENT');
      allow create: if hasPermission(request.resource.data.companyId, 'SHARE_CUSTOMER_STATEMENT') &&
        hasCompanyOnCreate(request.resource.data.companyId) &&
        request.resource.data.createdBy == request.auth.uid;
      allow delete: if isOwner(resource.data.companyId);
    }

    match /pricingRules/{ruleId} {
      allow read: if isMember(resource.data.companyId);
      allow create: if hasPermission(request.resource.data.companyId, 'MANAGE_PROMOTIONS') &&
        hasCompanyOnCreate(request.resource.data.companyId);
      allow update: if hasPermission(resource.data.companyId, 'MANAGE_PROMOTIONS') &&
        keepsCompany(resource.data.companyId);
      allow delete: if hasPermission(resource.data.companyId, 'MANAGE_PROMOTIONS');
    }

    match /companyPreferences/{companyId} {
      allow read: if isMember(companyId);
      allow create, update: if hasPermission(companyId, 'MANAGE_COMPANY_QUICK_ADD') &&
        request.resource.data.companyId == companyId;
    }

    match /supportReports/{reportId} {
      allow create: if signedIn() && isValidSupportReport(reportId);
      allow read: if isPlatformAdmin() || resource.data.createdBy == request.auth.uid;
      allow update, delete: if isPlatformAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if signedIn() && isValidSupportNotification(notificationId);
      allow read, update, delete: if isPlatformAdmin();
    }

    match /notificationDevices/{deviceId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
